ENVIRONMENT=production
# Railway recommended:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
#
# Manual format:
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=1440
FRONTEND_URL=https://sattest.uz
CORS_ORIGINS=["https://sattest.uz","https://www.sattest.uz"]
# Temporary-domain validation example:
# CORS_ORIGINS=["https://YOUR-VERCEL-PROJECT.vercel.app","https://sattest.uz","https://www.sattest.uz"]
# Optional for Vercel preview deployments. Prefer exact CORS_ORIGINS for production.
# CORS_ORIGIN_REGEX=https://.*\\.vercel\\.app
GRAPH_OUTPUT_DIR=static/graphs
RATE_LIMIT_PER_MINUTE=120
LOG_LEVEL=INFO
WEB_CONCURRENCY=2
WEB_TIMEOUT=120

# Required for production signup email codes.
# Use your domain mailbox/transactional SMTP provider values.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=no-reply@sattest.uz
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_EMAIL=no-reply@sattest.uz
SMTP_FROM_NAME=SATTEST.UZ Email Bot
EMAIL_VERIFICATION_FALLBACK_ENABLED=true

# Preferred transactional email provider.
# If set, the backend sends verification codes through Resend instead of SMTP.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
# Use no-reply@sattest.uz after verifying sattest.uz in Resend.
# For temporary testing before domain verification, use: SATTEST.UZ Email Bot <onboarding@resend.dev>
RESEND_FROM_EMAIL=SATTEST.UZ Email Bot <no-reply@sattest.uz>

# Telegram payment bot.
# Create the bot in @BotFather, keep the token secret, and set TELEGRAM_ADMIN_CHAT_ID to Founder's Telegram chat id.
# Valid receipt captions activate Pro immediately; Founder can revoke manually after checking payment records.
# Use TELEGRAM_WEBHOOK_SECRET for both Telegram's webhook secret header and the daily Pro report cron endpoint.
TELEGRAM_BOT_TOKEN=123456789:replace-with-botfather-token
TELEGRAM_WEBHOOK_SECRET=replace-with-random-webhook-secret
TELEGRAM_ADMIN_CHAT_ID=123456789
TELEGRAM_CHANNEL_ID=-1001234567890
ADMIN_CHAT_ID=123456789
PAYME_QR_URL=https://example.com/payme-qr.png
CLICK_QR_URL=https://example.com/click-qr.png
